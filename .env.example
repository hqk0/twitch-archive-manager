# Workspace Configuration (Default: ./workspace)
WORKSPACE_DIR="./workspace"

# Twitch API (Required for fetching metadata and chat)
TWITCH_CLIENT_ID="your_client_id"
TWITCH_CLIENT_SECRET="your_client_secret"

# Cloudflare D1 (Optional, required for 'worker' and 'list' commands)
CF_API_TOKEN="your_cloudflare_api_token"
CF_ACCOUNT_ID="your_cloudflare_account_id"
D1_DATABASE_ID="your_d1_database_id"

# Cloudflare R2 (Optional, for remote chat storage)
R2_ACCOUNT_ID="your_r2_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_bucket_name"

# YouTube Customization
YT_TITLE_TEMPLATE="%title%【%date%】"
YT_DESC_TEMPLATE_FILE="description_template.txt"
VIEWER_BASE_URL="https://your-viewer-site.pages.dev/watch"

# Notifications (Optional)
NTFY_URL="https://ntfy.sh"
NTFY_TOPIC=""
